# ── Multi-stream note ─────────────────────────────────────────────────────────
# Streams (channels) are managed via the UI or /api/streams. The settings below
# act as initial defaults seeded into each new channel's per-stream config when
# it is created for the first time. After that, every channel stores its own
# values in the database and the .env values are no longer read for that channel.

# ── Pipeline performance (initial channel defaults) ───────────────────────────
TARGET_FPS=15
JPEG_QUALITY=70

# ── Feature toggles (initial channel defaults) ────────────────────────────────
ENABLE_MOTION=false
ENABLE_ZONES=false
ENABLE_DETECTION=false
ENABLE_FACES=false

# ── Detection zones (initial channel defaults) ────────────────────────────────
# When to stop zone-triggered recording:
#   zone   — stop when there is no more movement inside any zone
#   stream — stop when there is no movement anywhere in the stream
ZONE_STOP_MODE=zone

# ── Motion tracking (initial channel defaults) ────────────────────────────────
MOTION_MIN_AREA=3500
MOTION_TRAIL_LENGTH=30
MOTION_MOG2_THRESHOLD=80
MOTION_DILATE_KERNEL=50

# Motion visual style — colors as hex strings
MOTION_TRAIL_ENABLED=true
MOTION_TRAIL_COLOR=#80f4dd
MOTION_TRAIL_MAX_RADIUS=7

MOTION_CONTOUR_ENABLED=false
MOTION_CONTOUR_COLOR=#fffdbd
MOTION_CONTOUR_THICKNESS=1

MOTION_ARROW_ENABLED=true
MOTION_ARROW_COLOR=#00c8ff
MOTION_ARROW_THICKNESS=2

MOTION_CENTER_ENABLED=true
MOTION_CENTER_COLOR=#ffc7c7
MOTION_CENTER_RADIUS=5

# ── Object detection / YOLOv8 (initial channel defaults) ─────────────────────
# Bare filenames are resolved to models/<name> automatically.
# Variants: yolov8n.pt (fastest) → yolov8s → yolov8m → yolov8l → yolov8x.pt (most accurate)
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4
YOLO_SKIP_FRAMES=3
# Comma-separated COCO class names to show; empty = all 80 classes
DETECT_CLASSES=

# ── Face recognition (initial channel defaults) ───────────────────────────────
# Models: Facenet512 (fast, default) | ArcFace (most accurate) | Facenet | VGG-Face
FACE_MODEL=Facenet512
FACE_SIMILARITY_THRESHOLD=0.4
FACE_SKIP_FRAMES=3
NOTIFY_ON_FACE_RECOGNIZED=False

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to repo root). Stores streams, zones, recordings,
# zone events, zone settings, per-stream config, face embeddings, and history.
DB_PATH=vip.db

# ── Notifications ─────────────────────────────────────────────────────────────
# Both channels are optional. Leave fields empty to disable that channel.
# Zone-trigger notifications and cooldown are toggled per-channel via the UI.
# Per-zone custom message templates are stored in the database (zone settings modal).
# Cooldown: minimum seconds between repeated alerts for the same zone.
NOTIFY_ON_ZONE_TRIGGER=false
NOTIFY_COOLDOWN=30

# Telegram — create a bot via @BotFather, get your chat_id via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_EMAIL=

# ── Recording ─────────────────────────────────────────────────────────────────
RECORDING_OUTPUT_DIR=recordings
RECORDING_PROJECT_NAME=vip
# Available tokens:
#   {project_name}      e.g. vip
#   {current_date}      e.g. 2026-04-23
#   {current_timestamp} e.g. 2026-04-23_14-31-42
#   {channel_number}    e.g. 1
#   {channel_slug}      e.g. front-door  (slugified channel name)
RECORDING_FILENAME_PATTERN={project_name}_{channel_number}_{current_timestamp}

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR  (use DEBUG for motion/zone diagnostics)
LOG_LEVEL=INFO
