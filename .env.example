# Video source: use 0 for local webcam, or an RTSP/MJPEG URL
STREAM_URL=0

# Target frames per second for the processing pipeline
TARGET_FPS=15

# JPEG encoding quality sent to the browser (1-100)
JPEG_QUALITY=70

# Feature toggles
ENABLE_MOTION=true
ENABLE_ZONES=true
ENABLE_DETECTION=false

# Path to SQLite database
DB_PATH=vip.db

# YOLOv8 model variant: yolov8n.pt | yolov8s.pt | yolov8m.pt
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4
# Run YOLO every N frames (reduces CPU load)
YOLO_SKIP_FRAMES=3
# Comma-separated class names to detect, or empty for all
DETECT_CLASSES=

# SMTP notification settings (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
NOTIFY_EMAIL=

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
